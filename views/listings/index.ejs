<% layout("/layouts/boilerplate") %>

<div class="container mt-5 mb-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-semibold">Explore Listings</h2>
  </div>

  <!-- SEARCH + FILTER BAR -->
  <form method="GET" action="/listings" class="row g-3 mb-4">

    <!-- Search -->
    <div class="col-md-3">
      <input 
        type="text" 
        name="search" 
        class="form-control" 
        placeholder="Search location or title"
        value="<%= query?.search || '' %>"
      >
    </div>

    <!-- Min Price -->
    <div class="col-md-2">
      <input 
        type="number" 
        name="minPrice" 
        class="form-control" 
        placeholder="Min Price"
        value="<%= query?.minPrice || '' %>"
      >
    </div>

    <!-- Max Price -->
    <div class="col-md-2">
      <input 
        type="number" 
        name="maxPrice" 
        class="form-control" 
        placeholder="Max Price"
        value="<%= query?.maxPrice || '' %>"
      >
    </div>

    <!-- CATEGORY (FIXED) -->
    <div class="col-md-2">
      <select name="category" class="form-select">
        <option value="">All Categories</option>

        <option value="Apartment" <%= query?.category === "Apartment" ? "selected" : "" %>>Apartment</option>
        <option value="House" <%= query?.category === "House" ? "selected" : "" %>>House</option>
        <option value="Villa" <%= query?.category === "Villa" ? "selected" : "" %>>Villa</option>
        <option value="Hotel" <%= query?.category === "Hotel" ? "selected" : "" %>>Hotel</option>
        <option value="Hostel" <%= query?.category === "Hostel" ? "selected" : "" %>>Hostel</option>
        <option value="Resort" <%= query?.category === "Resort" ? "selected" : "" %>>Resort</option>
        <option value="Cottage" <%= query?.category === "Cottage" ? "selected" : "" %>>Cottage</option>
        <option value="Cabin" <%= query?.category === "Cabin" ? "selected" : "" %>>Cabin</option>
        <option value="Farm Stay" <%= query?.category === "Farm Stay" ? "selected" : "" %>>Farm Stay</option>
        <option value="Camping" <%= query?.category === "Camping" ? "selected" : "" %>>Camping</option>
        <option value="Luxury" <%= query?.category === "Luxury" ? "selected" : "" %>>Luxury</option>
        <option value="Beachfront" <%= query?.category === "Beachfront" ? "selected" : "" %>>Beachfront</option>
        <option value="Mountain View" <%= query?.category === "Mountain View" ? "selected" : "" %>>Mountain View</option>
        <option value="City Stay" <%= query?.category === "City Stay" ? "selected" : "" %>>City Stay</option>

      </select>
    </div>

    <!-- Sort -->
    <div class="col-md-2">
      <select name="sort" class="form-select">
        <option value="">Sort</option>
        <option value="low" <%= query?.sort === "low" ? "selected" : "" %>>Price: Low to High</option>
        <option value="high" <%= query?.sort === "high" ? "selected" : "" %>>Price: High to Low</option>
      </select>
    </div>

    <!-- Button -->
    <div class="col-md-1 d-grid">
      <button class="btn btn-dark">Go</button>
    </div>

  </form>

  <!-- MAP -->
  <div id="map" style="height: 500px; width: 100%; margin-bottom: 30px; border-radius: 12px;"></div>

  <% if (allListings.length === 0) { %>

    <div class="text-center text-muted mt-5">
      <h5>No listings found</h5>
      <p>Try adjusting your filters</p>
    </div>

  <% } %>

  <!-- LISTINGS -->
  <div class="row g-4">

    <% for (let listing of allListings) { %>

      <div class="col-lg-4 col-md-6 col-sm-12">

        <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">

          <div class="card listing-card h-100">

            <div class="position-relative">

              <% if (listing.images && listing.images.length > 0) { %>

                <img
                  src="<%= listing.images[0].url %>"
                  class="card-img-top"
                  style="height:250px; object-fit:cover;"
                >

              <% } else { %>

                <img
                  src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85"
                  class="card-img-top"
                  style="height:250px; object-fit:cover;"
                >

              <% } %>

            </div>

            <div class="card-body">

              <h6 class="fw-semibold mb-1">
                <%= listing.title %>
              </h6>

              <p class="text-muted small mb-1">
                <%= listing.location %>, <%= listing.country %>
              </p>

              <p class="fw-semibold mb-0">
                ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
                <span class="text-muted fw-normal"> / night</span>
              </p>

              <!-- CATEGORY TAG (NEW) -->
              <span class="badge bg-light text-dark mt-2">
                <%= listing.category %>
              </span>

            </div>

          </div>

        </a>

      </div>

    <% } %>

  </div>

</div>

<!-- DATA -->
<script id="listing-data" type="application/json">
  <%- JSON.stringify(allListings) %>
</script>

<script>
  const listings = JSON.parse(document.getElementById("listing-data").textContent);
</script>

<script src="/js/map.js"></script>

