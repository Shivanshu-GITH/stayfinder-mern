<% layout("/layouts/boilerplate") %>

<div class="container edit-page-container">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">

      <div class="edit-card">
        <h2 class="edit-title">Edit Listing</h2>

        <!-- CURRENT IMAGES -->
        <div class="mb-4">
          <label class="form-label">Current Images</label>

          <div class="d-flex flex-wrap gap-3">

            <% if (listing.images && listing.images.length > 0) { %>

              <% for (let img of listing.images) { %>

                <div class="uploaded-image-wrapper">

                  <img
                    src="<%= img.url %>"
                    class="uploaded-image-item"
                  >

                  <form
                    action="/listings/<%= listing._id %>/images?_method=DELETE"
                    method="POST"
                    class="uploaded-image-delete-form"
                  >

                    <input
                      type="hidden"
                      name="filename"
                      value="<%= img.filename %>"
                    >

                    <button
                      type="submit"
                      class="uploaded-image-delete-btn">
                      ×
                    </button>

                  </form>

                </div>

              <% } %>

            <% } else { %>

              <p class="text-muted">No images uploaded</p>

            <% } %>

          </div>
        </div>

        <!-- MAIN FORM -->
        <form action="/listings/<%= listing._id %>?_method=PUT"
              method="POST"
              enctype="multipart/form-data"
              class="needs-validation"
              novalidate>

          <!-- TITLE -->
          <div class="mb-4">
            <label class="form-label">Title</label>
            <input
              type="text"
              name="listing[title]"
              value="<%= listing.title %>"
              class="form-control"
              required
              minlength="5"
            >
          </div>

          <!-- DESCRIPTION -->
          <div class="mb-4">
            <label class="form-label">Description</label>
            <textarea
              name="listing[description]"
              class="form-control"
              rows="4"
              required
              minlength="20"><%= listing.description %></textarea>
          </div>

          <!-- CATEGORY (NEW) -->
          <div class="mb-4">
            <label class="form-label">Category</label>

            <% const categories = [
              "Apartment",
              "House",
              "Villa",
              "Hotel",
              "Hostel",
              "Resort",
              "Cottage",
              "Cabin",
              "Farm Stay",
              "Camping",
              "Luxury",
              "Beachfront",
              "Mountain View",
              "City Stay"
            ]; %>

            <select name="listing[category]" class="form-control" required>

              <% for (let cat of categories) { %>

                <option value="<%= cat %>"
                  <%= listing.category === cat ? "selected" : "" %>>
                  <%= cat %>
                </option>

              <% } %>

            </select>
          </div>

          <!-- IMAGE UPLOAD -->
          <div class="mb-4">

            <label class="form-label">Upload New Images</label>

            <input
              type="file"
              id="images"
              name="images"
              multiple
              class="form-control"
              accept="image/*"
            >

            <div id="imagePreviewContainer"
                 class="mt-3 d-flex flex-wrap image-preview-grid">
            </div>

          </div>

          <div class="row">

            <!-- PRICE -->
            <div class="mb-4 col-md-4">
              <label class="form-label">Price (₹)</label>
              <input
                type="number"
                name="listing[price]"
                value="<%= listing.price %>"
                class="form-control"
                required
              >
            </div>

            <!-- COUNTRY -->
            <div class="mb-4 col-md-8">
              <label class="form-label">Country</label>
              <input
                type="text"
                name="listing[country]"
                value="<%= listing.country %>"
                class="form-control"
                required
              >
            </div>

          </div>

          <!-- LOCATION -->
          <div class="mb-4">
            <label class="form-label">Location</label>
            <input
              type="text"
              name="listing[location]"
              value="<%= listing.location %>"
              class="form-control"
              required
            >
          </div>

          <button class="btn save-btn w-100 mt-3">
            Save Changes
          </button>

        </form>

      </div>

    </div>
  </div>
</div>

<!-- IMAGE PREVIEW -->
<script>
const imageInput = document.getElementById("images");
const previewContainer = document.getElementById("imagePreviewContainer");

imageInput.addEventListener("change", function () {
  previewContainer.innerHTML = "";

  Array.from(this.files).forEach(file => {
    const img = document.createElement("img");
    img.src = URL.createObjectURL(file);
    img.className = "image-preview-item";
    previewContainer.appendChild(img);
  });
});
</script>

