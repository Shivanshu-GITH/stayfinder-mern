<% layout("/layouts/boilerplate") %>

<div class="container edit-page-container">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">

      <div class="edit-card">
        <h2 class="edit-title">Create a New Listing</h2>

        <form 
          action="/listings" 
          method="POST" 
          enctype="multipart/form-data"
          class="needs-validation" 
          novalidate
        >
          
          <!-- TITLE -->
          <div class="mb-4">
            <label class="form-label">Title</label>
            <input 
              type="text" 
              name="listing[title]" 
              class="form-control"
              placeholder="Give your place a catchy title"
              required
              minlength="5"
            />
            <div class="invalid-feedback">
              Title must be at least 5 characters long.
            </div>
          </div>

          <!-- DESCRIPTION -->
          <div class="mb-4">
            <label class="form-label">Description</label>
            <textarea 
              name="listing[description]" 
              class="form-control"
              rows="4"
              placeholder="Describe the vibe of your place..."
              required
              minlength="20"
            ></textarea>
            <div class="invalid-feedback">
              Description must be at least 20 characters long.
            </div>
          </div>

          <!-- MULTIPLE IMAGE UPLOAD -->
          <div class="mb-4">
            <label class="form-label">Upload Images</label>

            <input 
              type="file" 
              id="images"
              name="images"
              multiple
              class="form-control"
              accept="image/*"
            />

            <!-- preview container -->
            <div id="imagePreviewContainer" class="mt-3 d-flex flex-wrap gap-2"></div>
          </div>

          <div class="row">

            <!-- PRICE -->
            <div class="mb-4 col-md-4">
              <label class="form-label">Price (₹)</label>
              <input 
                type="number" 
                name="listing[price]" 
                class="form-control"
                placeholder="e.g. 1200"
                required
                min="1"
              />
              <div class="invalid-feedback">
                Price must be greater than 0.
              </div>
            </div>

            <!-- COUNTRY -->
            <div class="mb-4 col-md-8">
              <label class="form-label">Country</label>
              <input 
                type="text" 
                name="listing[country]" 
                class="form-control"
                placeholder="India"
                required
                pattern="^[A-Za-z ]+$"
              />
              <div class="invalid-feedback">
                Country name must contain letters only.
              </div>
            </div>

          </div>

          <!-- LOCATION -->
          <div class="mb-4">
            <label class="form-label">Location</label>
            <input 
              type="text" 
              name="listing[location]" 
              class="form-control"
              placeholder="Jaipur, Rajasthan"
              required
              pattern="^[A-Za-z ,]+$"
            />
            <div class="invalid-feedback">
              Location should contain only letters and commas.
            </div>
          </div>

          <button class="btn save-btn w-100 mt-3">
            Add Listing
          </button>

        </form>
      </div>

    </div>
  </div>
</div>

<!-- ================= MULTIPLE IMAGE PREVIEW SCRIPT ================= -->

<script>

const imageInput = document.getElementById("images");
const previewContainer = document.getElementById("imagePreviewContainer");

let selectedFiles = [];

imageInput.addEventListener("change", function () {

  const files = Array.from(this.files);

  files.forEach(file => {

    // store file in array
    selectedFiles.push(file);

    const img = document.createElement("img");

    img.src = URL.createObjectURL(file);

    img.style.width = "120px";
    img.style.height = "120px";
    img.style.objectFit = "cover";
    img.style.borderRadius = "10px";

    previewContainer.appendChild(img);

  });

});

</script>
